rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - allow read for authenticated users with field restrictions
    match /users/{userId} {
      // Allow list queries for username checking (unauthenticated)
      allow list: if true;
      
      allow read: if request.auth != null && 
        (request.auth.uid == userId || 
         // Non-owners can only read safe fields
         (!resource.data.keys().hasAny(['password', 'hash', 'salt', 'token', 'secret', 'key']) &&
          resource.data.keys().size() <= 5));
      allow write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Debug: Log all user collection access attempts
      // This will show up in Firebase Console logs
    }
    
    // Users subcollections - specific rules first
    
    // Profile ranking data: any signed-in user may read; only the owner may write
    match /users/{userId}/movieData/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/tvData/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/peopleData/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/directorsData/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/watchlistData/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    // Legacy data subcollection (backwards compatibility)
    match /users/{userId}/data/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    // Users subcollections - fallback rule for any other subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Friends collection - more permissive reading and writing
    match /friends/{friendId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.friendUid == request.auth.uid);
      allow delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || resource.data.friendUid == request.auth.uid);
    }
    
    // Allow querying friends list (for viewing friends of friends)
    match /friends {
      allow list, get: if request.auth != null;
    }
    
    // Friend requests collection
    match /friendRequests/{requestId} {
      // Users can read requests sent to them or by them
      allow read: if request.auth != null && 
        (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
      
      // Users can create requests they send
      allow create: if request.auth != null && 
        request.resource.data.from == request.auth.uid &&
        request.resource.data.from != request.resource.data.to;
      
      // Users can delete requests sent to them (accept/reject) or by them (cancel)
      allow delete: if request.auth != null && 
        (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
    }
    
    // Movies collection - users can read their own and friends' rankings
    match /movies/{movieId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // TV collection - users can read their own and friends' rankings
    match /tv/{tvId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // People (actors) collection - users can read their own and friends' rankings
    match /people/{personId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Directors collection - users can read their own and friends' rankings
    match /directors/{directorId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Watchlist collection - users can read/write their own watchlist
    match /watchlist/{watchlistId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Settings collection - users can read/write their own settings
    match /settings/{settingsId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
