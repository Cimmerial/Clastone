rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public user doc read (signed-out + people search): never store credentials in Firestore — Auth holds secrets.
    // No arbitrary field-count cap (that broke real profiles and full-collection search when any doc was "too large").
    function userProfileDocPublicSafe() {
      return resource != null
        && !resource.data.keys().hasAny(['password', 'hash', 'salt']);
    }

    // Users collection
    match /users/{userId} {
      function isDevAdmin() {
        return request.auth != null && request.auth.token.email == "cimmerial@clastone.local";
      }
      function adminOnlyUpdatesDevRole() {
        return isDevAdmin()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['devRole'])
          && (
            request.resource.data.devRole == null
            || request.resource.data.devRole is string
          );
      }
      // Allow list queries for username checking (unauthenticated)
      allow list: if true;

      // Owner: full doc. Others (including signed-out): only small docs without sensitive keys.
      allow read: if request.auth != null && request.auth.uid == userId
        || userProfileDocPublicSafe();
      allow write: if (request.auth != null && request.auth.uid == userId) || adminOnlyUpdatesDevRole();
      allow create: if request.auth != null && request.auth.uid == userId;
      // Debug: Log all user collection access attempts
      // This will show up in Firebase Console logs
    }
    
    // Users subcollections - specific rules first
    
    // Profile ranking data: public read; only the owner may write
    match /users/{userId}/movieData/{docId} {
      allow read: if true;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/tvData/{docId} {
      allow read: if true;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/peopleData/{docId} {
      allow read: if true;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/directorsData/{docId} {
      allow read: if true;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    match /users/{userId}/watchlistData/{docId} {
      allow read: if true;
      allow write: if request.auth != null && userId == request.auth.uid;
    }

    match /users/{userId}/listsData/{docId} {
      allow read, write: if request.auth != null && userId == request.auth.uid;
    }

    // Friend watch recommendations: stored on the recipient's user doc. Senders may
    // create/delete only when a friends/{sender_recipient} document exists.
    match /users/{userId}/incomingWatchRecommendations/{recId} {
      function friendshipExists(a, b) {
        return exists(/databases/$(database)/documents/friends/$(a + '_' + b));
      }
      // Recipient may read all. Friends of the recipient may read (FriendProfilePage merges
      // incoming into watchlist for viewers). Senders may read docs they created.
      // Friends check also covers sender get() on missing docs (resource == null).
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        friendshipExists(request.auth.uid, userId) ||
        friendshipExists(userId, request.auth.uid) ||
        (resource != null && resource.data.fromUid == request.auth.uid)
      );
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.toUid == userId &&
        friendshipExists(request.auth.uid, userId);
      allow update: if request.auth != null &&
        resource.data.fromUid == request.auth.uid &&
        request.resource.data.fromUid == resource.data.fromUid &&
        request.resource.data.toUid == resource.data.toUid &&
        request.resource.data.toUid == userId &&
        friendshipExists(request.auth.uid, userId);
      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        resource.data.fromUid == request.auth.uid
      );
    }
    
    // Legacy data subcollection (backwards compatibility)
    match /users/{userId}/data/{docId} {
      allow read: if true;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
    
    // Users subcollections - fallback rule for any other subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Friends collection - more permissive reading and writing
    match /friends/{friendId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.friendUid == request.auth.uid);
      allow delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || resource.data.friendUid == request.auth.uid);
    }
    
    // Allow querying friends list (for viewing friends of friends)
    match /friends {
      allow list, get: if request.auth != null;
    }
    
    // Friend requests collection
    match /friendRequests/{requestId} {
      // Users can read requests sent to them or by them
      allow read: if request.auth != null && 
        (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
      
      // Users can create requests they send
      allow create: if request.auth != null && 
        request.resource.data.from == request.auth.uid &&
        request.resource.data.from != request.resource.data.to;
      
      // Users can delete requests sent to them (accept/reject) or by them (cancel)
      allow delete: if request.auth != null && 
        (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
    }
    
    // Movies collection - users can read their own and friends' rankings
    match /movies/{movieId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // TV collection - users can read their own and friends' rankings
    match /tv/{tvId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // People (actors) collection - users can read their own and friends' rankings
    match /people/{personId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Directors collection - users can read their own and friends' rankings
    match /directors/{directorId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users to read
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Watchlist collection - users can read/write their own watchlist
    match /watchlist/{watchlistId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Settings collection - users can read/write their own settings
    match /settings/{settingsId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Global predefined collections are visible to all authenticated users.
    // Only the developer account can write.
    match /globalCollections/{collectionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "cimmerial@clastone.local";
    }

    // Global quotes are visible to all authenticated users.
    // Developer account and BabyDev users can write.
    match /globalQuotes/{quoteId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.email == "cimmerial@clastone.local" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.devRole == "babydev"
        )
      );
    }
  }
}
